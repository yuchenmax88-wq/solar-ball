FROM python:3.11-slim

LABEL org.opencontainers.image.title="Solar Ball Test Runner"
LABEL org.opencontainers.image.description="Automated test runner for Solar Ball firmware and tools"
LABEL org.opencontainers.image.version="1.3.0"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY tools/requirements.txt ./tools/
RUN pip install --no-cache-dir -r tools/requirements.txt

COPY . .

ENTRYPOINT ["python", "tests/run_all.py"]
